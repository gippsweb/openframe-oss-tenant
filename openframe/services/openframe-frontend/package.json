{
  "name": "openframe-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p ${PORT:-3000}",
    "dev:turbo": "next dev -p ${PORT:-3000}",
    "build": "next build",
    "build:local": "next build --webpack",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
