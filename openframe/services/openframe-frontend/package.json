    "@tanstack/react-query": "^5.90.16",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "date-fns": "^4.1.0",
    "graphql": "^16.8.0",
    "graphql-tag": "^2.12.6",
    "highlight.js": "^11.11.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.454.0",
    "next": "^16.0.10",
    "next-runtime-env": "^3.2.2",
    "react": "^19.2.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.2.0",
